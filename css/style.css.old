@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&family=Great+Vibes&display=swap');

@keyframes flicker {

  0%,
  18%,
  22%,
  25%,
  53%,
  57%,
  100% {
    opacity: 1;
    filter: brightness(1);
  }

  20% {
    opacity: 0.6;
    filter: brightness(0.7);
  }

  24% {
    opacity: 0.9;
    filter: brightness(1.1);
  }

  55% {
    opacity: 0.7;
    filter: brightness(0.8);
  }

  56% {
    opacity: 1;
    filter: brightness(1.15);
  }
}

@keyframes bloom {
  0% {
    filter: brightness(1) drop-shadow(0 0 0px rgba(212, 168, 83, 0));
  }

  40% {
    filter: brightness(1.3) drop-shadow(0 0 18px rgba(212, 168, 83, 0.6));
  }

  70% {
    filter: brightness(1.15) drop-shadow(0 0 35px rgba(232, 115, 90, 0.4));
  }

  100% {
    filter: brightness(1.2) drop-shadow(0 0 22px rgba(212, 168, 83, 0.45));
  }
}

@keyframes ken-burns {
  0% {
    transform: scale(1) rotate(0deg) translateX(0);
  }

  50% {
    transform: scale(1.08) rotate(0.3deg) translateX(-8px);
  }

  100% {
    transform: scale(1.15) rotate(-0.2deg) translateX(6px);
  }
}

@keyframes cinematic-reveal {
  0% {
    opacity: 0;
    filter: blur(40px) brightness(2);
    transform: translateY(40px) scale(0.97);
  }

  40% {
    opacity: 0.7;
    filter: blur(8px) brightness(1.1);
    transform: translateY(10px) scale(0.99);
  }

  100% {
    opacity: 1;
    filter: blur(0) brightness(1);
    transform: translateY(0) scale(1);
  }
}

@keyframes cursor-ring-pulse {
  0% {
    box-shadow: 0 0 0 0 rgba(212, 168, 83, 0.5);
  }

  50% {
    box-shadow: 0 0 0 8px rgba(212, 168, 83, 0);
  }

  100% {
    box-shadow: 0 0 0 0 rgba(212, 168, 83, 0);
  }
}

@keyframes cursor-dot-idle {

  0%,
  100% {
    transform: translate(-50%, -50%) scale(1);
  }

  50% {
    transform: translate(-50%, -50%) scale(1.6);
    opacity: 0.6;
  }
}

@keyframes btn-shimmer {
  0% {
    left: -120%;
  }

  100% {
    left: 160%;
  }
}

@keyframes btn-ripple {
  0% {
    transform: translate(-50%, -50%) scale(0);
    opacity: 0.5;
  }

  100% {
    transform: translate(-50%, -50%) scale(4);
    opacity: 0;
  }
}

@keyframes marquee-glow-pass {
  0% {
    background-position: -200% center;
  }

  100% {
    background-position: 200% center;
  }
}

@keyframes marquee-scroll {
  0% {
    transform: translateX(0);
  }

  100% {
    transform: translateX(-50%);
  }
}

@keyframes glow-pulse {
  0% {
    opacity: 0.4;
    transform: translateX(-50%) scale(1) rotate(0deg);
  }

  50% {
    opacity: 0.9;
    transform: translateX(-50%) scale(1.25) rotate(3deg);
  }

  100% {
    opacity: 0.6;
    transform: translateX(-50%) scale(1.1) rotate(-2deg);
  }
}

@keyframes grain {

  0%,
  100% {
    transform: translate(0, 0);
  }

  10% {
    transform: translate(-6%, -11%);
  }

  20% {
    transform: translate(4%, 7%);
  }

  30% {
    transform: translate(-9%, 3%);
  }

  40% {
    transform: translate(6%, -8%);
  }

  50% {
    transform: translate(-3%, 12%);
  }

  60% {
    transform: translate(8%, -5%);
  }

  70% {
    transform: translate(-5%, 9%);
  }

  80% {
    transform: translate(3%, -4%);
  }

  90% {
    transform: translate(-7%, 6%);
  }
}

@keyframes float-hint {

  0%,
  100% {
    transform: translateX(-50%) translateY(0);
    opacity: 0.7;
  }

  50% {
    transform: translateX(-50%) translateY(12px);
    opacity: 1;
  }
}

@keyframes seat-pop {
  0% {
    box-shadow: 0 0 0 0 rgba(212, 168, 83, 0.7);
  }

  60% {
    box-shadow: 0 0 0 14px rgba(212, 168, 83, 0.1);
  }

  100% {
    box-shadow: 0 0 0 22px rgba(212, 168, 83, 0);
  }
}

@keyframes page-wipe-in {
  0% {
    clip-path: inset(0 100% 0 0);
  }

  100% {
    clip-path: inset(0 0% 0 0);
  }
}

@keyframes page-wipe-out {
  0% {
    clip-path: inset(0 0 0 0%);
  }

  100% {
    clip-path: inset(0 0 0 100%);
  }
}

.flicker {
  animation: flicker 5s infinite;
}

.bloom:hover {
  animation: bloom 0.8s var(--ease-smooth) forwards;
}

.kb-zoom {
  animation: ken-burns 25s ease-in-out infinite alternate;
}

.reveal {
  animation: cinematic-reveal 1.4s var(--ease-smooth) forwards;
}

:root {
  --bg-deep: #0D0B0E;
  --bg-dark: #1A1520;
  --bg-card: #221C2A;
  --gold: #D4A853;
  --gold-light: #E8C97A;
  --gold-dim: rgba(212, 168, 83, 0.15);
  --sunset-coral: #E8735A;
  --sunset-rose: #C4637A;
  --sunset-lavender: #8B6FA3;
  --teal-deep: #1B4B5A;
  --teal-light: #2A7A7A;
  --cream: #F2E8D5;
  --cream-dim: rgba(242, 232, 213, 0.85);
  --mocha: #9A8B7A;
  --dusty-pink: #D4A0A0;
  --noir: #141118;

  --retro-red: #B22222;
  --retro-red-glow: rgba(178, 34, 34, 0.4);
  --retro-mint: #92B4A7;
  --font-display: 'Oswald', sans-serif;
  --font-body: 'Oswald', sans-serif;
  --font-accent: 'Apple Garamond', 'EB Garamond', serif;
  --font-calligraphy: 'Great Vibes', cursive;

  --ease-smooth: cubic-bezier(0.25, 0.1, 0.25, 1);
  --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
  --transition: all 0.5s var(--ease-smooth);
}

*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  background: var(--bg-deep);
  background-image:
    radial-gradient(circle at 50% 30%, rgba(212, 168, 83, 0.05) 0%, transparent 60%),
    linear-gradient(rgba(13, 11, 14, 0.1), rgba(13, 11, 14, 0.1));
  background-attachment: fixed;
  color: var(--cream);
  font-family: var(--font-body);
  font-size: 18px;
  line-height: 1.8;
  letter-spacing: 0.01em;
  overflow-x: hidden;
}

::selection {
  background: var(--gold);
  color: var(--bg-deep);
}

.film-grain {
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity: 0.035;
  pointer-events: none;
  z-index: 9990;
  animation: grain 0.65s steps(6) infinite;
}

.page-transition {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 99998;
  pointer-events: none;
  display: flex;
  justify-content: center;
  align-items: center;
  background: var(--bg-deep);
  opacity: 0;
  transition: opacity 0.5s ease;
}

.page-transition.active {
  opacity: 1;
  pointer-events: all;
  animation: page-wipe-in 0.5s var(--ease-smooth) forwards;
}

.page-transition .trans-logo {
  position: relative;
  z-index: 2;
  font-family: var(--font-display);
  font-style: italic;
  font-size: 3rem;
  color: var(--gold);
  letter-spacing: 0.2em;
  opacity: 0;
  transform: scale(0.85) translateY(10px);
  transition: opacity 0.5s ease 0.25s, transform 0.5s var(--ease-bounce) 0.25s;
}

.page-transition.active .trans-logo {
  opacity: 1;
  transform: scale(1) translateY(0);
}

.page-transition.fade-out {
  opacity: 0;
  animation: page-wipe-out 0.45s var(--ease-smooth) forwards;
}

h1,
h2,
h3,
h4,
h5,
h6 {
  font-family: var(--font-display);
  font-weight: 400;
  color: var(--gold);
  letter-spacing: 0.06em;
  line-height: 1.2;
}

h1 {
  font-size: clamp(2.5rem, 6vw, 5rem);
  text-transform: uppercase;
}

h2 {
  font-size: clamp(1.8rem, 3vw, 3rem);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

h3 {
  font-size: clamp(1.3rem, 2vw, 2rem);
}

p {
  font-family: var(--font-body);
  color: var(--cream-dim);
}

a {
  color: var(--gold);
  text-decoration: none;
  transition: var(--transition);
}

a:hover {
  color: var(--sunset-coral);
}

.lumiere-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  padding: 20px 5%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(180deg, rgba(13, 11, 14, 0.95) 0%, rgba(13, 11, 14, 0.6) 70%, transparent 100%);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.lumiere-logo {
  display: flex;
  align-items: center;
  gap: 15px;
}

.lumiere-logo img {
  height: 55px;
  filter: drop-shadow(0 0 20px rgba(212, 168, 83, 0.3));
  transition: var(--transition);
}

.lumiere-logo img:hover {
  filter: drop-shadow(0 0 35px rgba(212, 168, 83, 0.7));
  transform: scale(1.06) rotate(-1deg);
}

.nav-links {
  display: flex;
  gap: 45px;
  align-items: center;
}

.nav-link {
  font-family: var(--font-accent);
  font-size: 1.1rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  position: relative;
  padding-bottom: 4px;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 1.5px;
  background: linear-gradient(90deg, var(--gold), var(--sunset-coral));
  transition: width 0.4s var(--ease-smooth), left 0.4s var(--ease-smooth);
}

.nav-link:hover::after {
  width: 100%;
  left: 0;
}

.btn-primary {
  display: inline-block;
  background: transparent;
  color: var(--gold);
  border: 1.5px solid var(--gold);
  padding: 14px 40px;
  font-family: var(--font-accent);
  font-size: 1.05rem;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition:
    color 0.4s ease,
    border-color 0.4s ease,
    box-shadow 0.4s ease,
    transform 0.4s var(--ease-bounce);
  isolation: isolate;
}

.btn-primary::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 100%;
  height: 0%;
  background: var(--gold);
  transition: height 0.45s var(--ease-smooth);
  z-index: -1;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -120%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.25), transparent);
  transform: skewX(-20deg);
  z-index: 1;
  pointer-events: none;
}

.btn-primary:hover {
  color: var(--bg-deep);
  border-color: var(--gold);
  box-shadow: 0 12px 35px rgba(212, 168, 83, 0.4);
  transform: translateY(-3px);
}

.btn-primary:hover::after {
  height: 102%;
}

.btn-primary:hover::before {
  animation: btn-shimmer 0.65s var(--ease-smooth) forwards;
}

.btn-primary:active {
  transform: translateY(0px) scale(0.97);
  box-shadow: 0 4px 12px rgba(212, 168, 83, 0.25);
  transition: transform 0.1s ease, box-shadow 0.1s ease;
}

.btn-coral {
  display: inline-block;
  background: linear-gradient(135deg, var(--sunset-coral), var(--sunset-rose));
  color: #fff;
  border: none;
  padding: 14px 40px;
  font-family: var(--font-accent);
  font-size: 1.05rem;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: transform 0.4s var(--ease-bounce), box-shadow 0.4s ease;
  box-shadow: 0 4px 20px rgba(232, 115, 90, 0.3);
  border-radius: 2px;
  isolation: isolate;
}

.btn-coral::before {
  content: '';
  position: absolute;
  top: -10%;
  left: -130%;
  width: 55%;
  height: 120%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.45), transparent);
  transform: skewX(-22deg);
  z-index: 1;
  pointer-events: none;
}

.btn-coral::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10px;
  height: 10px;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  transform: translate(-50%, -50%) scale(0);
  z-index: 0;
  pointer-events: none;
}

.btn-coral:hover {
  transform: translateY(-5px) scale(1.02);
  box-shadow: 0 16px 45px rgba(232, 115, 90, 0.65);
}

.btn-coral:hover::before {
  animation: btn-shimmer 0.6s var(--ease-smooth) forwards;
}

.btn-coral:active {
  transform: translateY(-1px) scale(0.98);
  box-shadow: 0 5px 15px rgba(232, 115, 90, 0.3);
}

.btn-coral:active::after {
  animation: btn-ripple 0.5s ease-out forwards;
}

.vintage-card {
  background: linear-gradient(145deg, rgba(34, 28, 42, 0.9), rgba(26, 21, 32, 0.95));
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(212, 168, 83, 0.15);
  border-radius: 8px;
  padding: 45px;
  position: relative;
  box-shadow: 0 25px 60px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(212, 168, 83, 0.1);
}

.corner-dec {
  position: absolute;
  width: 20px;
  height: 20px;
  opacity: 0.4;
}

.corner-dec::before,
.corner-dec::after {
  content: '';
  position: absolute;
  background: var(--gold);
}

.corner-tl {
  top: 12px;
  left: 12px;
}

.corner-tl::before {
  width: 20px;
  height: 1px;
  top: 0;
  left: 0;
}

.corner-tl::after {
  width: 1px;
  height: 20px;
  top: 0;
  left: 0;
}

.corner-tr {
  top: 12px;
  right: 12px;
}

.corner-tr::before {
  width: 20px;
  height: 1px;
  top: 0;
  right: 0;
}

.corner-tr::after {
  width: 1px;
  height: 20px;
  top: 0;
  right: 0;
}

.corner-bl {
  bottom: 12px;
  left: 12px;
}

.corner-bl::before {
  width: 20px;
  height: 1px;
  bottom: 0;
  left: 0;
}

.corner-bl::after {
  width: 1px;
  height: 20px;
  bottom: 0;
  left: 0;
}

.corner-br {
  bottom: 12px;
  right: 12px;
}

.corner-br::before {
  width: 20px;
  height: 1px;
  bottom: 0;
  right: 0;
}

.corner-br::after {
  width: 1px;
  height: 20px;
  bottom: 0;
  right: 0;
}

.form-group {
  margin-bottom: 28px;
  position: relative;
}

.form-group label {
  display: block;
  margin-bottom: 8px;
  font-family: var(--font-accent);
  color: var(--mocha);
  font-size: 1.05rem;
  letter-spacing: 0.05em;
}

.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  background: rgba(255, 255, 255, 0.03);
  border: none;
  border-bottom: 1.5px solid rgba(212, 168, 83, 0.25);
  padding: 12px 8px;
  color: var(--cream);
  font-family: var(--font-body);
  font-size: 1.15rem;
  outline: none;
  transition: var(--transition);
}

.form-group input:focus {
  border-bottom-color: var(--sunset-coral);
  background: rgba(232, 115, 90, 0.03);
}

.form-group input::placeholder {
  color: rgba(154, 139, 122, 0.4);
}

.divider {
  width: 100%;
  height: 1px;
  margin: 50px 0;
  position: relative;
  background: linear-gradient(90deg, transparent, var(--gold), var(--sunset-coral), var(--gold), transparent);
}

.divider::after {
  content: '✦';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--bg-deep);
  padding: 0 15px;
  color: var(--gold);
  font-size: 0.8rem;
}

.marquee-container {
  position: absolute;
  top: 0;
  width: 100%;
  z-index: 50;
  background: linear-gradient(90deg, var(--sunset-coral), var(--sunset-rose), var(--sunset-lavender));
  padding: 10px 0;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(232, 115, 90, 0.3);
}

.marquee-container::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.12) 40%, rgba(255, 255, 255, 0.06) 50%, transparent 100%);
  background-size: 200% 100%;
  animation: marquee-glow-pass 3.5s linear infinite;
  pointer-events: none;
}

.marquee {
  display: flex;
  width: fit-content;
  animation: marquee-scroll 30s linear infinite;
  white-space: nowrap;
}

.marquee span {
  font-family: var(--font-accent);
  font-size: 1rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #fff;
  padding-right: 60px;
  display: inline-flex;
  align-items: center;
}

.marquee span::after {
  content: '★';
  margin-left: 60px;
  color: var(--gold-light);
}

.hp-hero {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  filter: brightness(0.3) saturate(1.3);
  z-index: 0;
}

.hero-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at center, rgba(13, 11, 14, 0.3) 0%, rgba(13, 11, 14, 0.9) 100%);
}

.hero-glow {
  position: absolute;
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232, 115, 90, 0.15) 0%, transparent 70%);
  top: 20%;
  left: 50%;
  transform: translateX(-50%);
  animation: glow-pulse 7s ease-in-out infinite alternate;
  z-index: 1;
}

.auth-wrapper {
  position: relative;
  z-index: 10;
  width: 100%;
  max-width: 460px;
  perspective: 1200px;
}

.auth-flip-box {
  position: relative;
  width: 100%;
  transition: transform 0.9s var(--ease-smooth);
  transform-style: preserve-3d;
}

.auth-wrapper.register-mode .auth-flip-box {
  transform: rotateY(180deg);
}

.auth-card {
  width: 100%;
  backface-visibility: hidden;
  position: absolute;
  top: 0;
  left: 0;
}

.auth-login {
  position: relative;
}

.auth-register {
  transform: rotateY(180deg);
}

.auth-header {
  text-align: center;
  margin-bottom: 35px;
}

.auth-header img {
  height: 80px;
  margin-bottom: 15px;
}

.auth-header h2 {
  font-size: 2rem;
  margin-bottom: 5px;
}

.auth-header p {
  color: var(--mocha);
  font-style: italic;
  font-family: var(--font-accent);
  font-size: 1.15rem;
}

.auth-toggle {
  text-align: center;
  margin-top: 25px;
  color: var(--mocha);
  font-family: var(--font-accent);
}

.auth-toggle a {
  cursor: pointer;
  margin-left: 5px;
  text-decoration: underline;
  text-underline-offset: 3px;
}

.movies-section {
  padding: 80px 5%;
}

.movies-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 40px;
}

.movie-card {
  position: relative;
  border-radius: 8px;
  overflow: hidden;
  background: var(--bg-card);
  cursor: pointer;
  transition: transform 0.55s var(--ease-bounce), box-shadow 0.55s var(--ease-smooth);
}

.movie-card:hover {
  transform: translateY(-14px) scale(1.025) rotate(-0.4deg);
  box-shadow: 0 25px 55px rgba(212, 168, 83, 0.18), 0 0 0 1px var(--gold);
}

.movie-poster-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/4;
}

.movie-poster-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 1.1s var(--ease-smooth), filter 0.6s;
  filter: saturate(0.9) contrast(1.05);
}

.movie-card:hover .movie-poster-wrap img {
  transform: scale(1.1);
  filter: saturate(1.25) contrast(1.1);
}

.movie-poster-wrap::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: linear-gradient(to top, var(--bg-card) 0%, transparent 100%);
  pointer-events: none;
}

.movie-info {
  padding: 25px 30px 30px;
  position: relative;
  z-index: 1;
  margin-top: -30px;
}

.movie-title {
  font-size: 1.5rem;
  margin-bottom: 5px;
  color: var(--cream);
  font-family: var(--font-display);
}

.movie-meta {
  color: var(--mocha);
  font-style: italic;
  font-size: 0.95rem;
  font-family: var(--font-accent);
}

.filter-ribbon {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 45px;
  padding: 18px 0;
  border-top: 1px solid rgba(212, 168, 83, 0.15);
  border-bottom: 1px solid rgba(212, 168, 83, 0.15);
}

.filter-group {
  display: flex;
  gap: 20px;
}

.filter-group select {
  background: transparent;
  color: var(--gold);
  border: none;
  border-bottom: 1px solid var(--mocha);
  padding: 8px;
  font-family: var(--font-accent);
  font-size: 1rem;
  outline: none;
  cursor: pointer;
  appearance: none;
}

.dashboard-header {
  padding: 180px 5% 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.dashboard-header .bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.2) saturate(1.2);
}

.dashboard-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200px;
  background: linear-gradient(to top, var(--bg-deep), transparent);
}

.dashboard-header * {
  position: relative;
  z-index: 2;
}

.detail-hero {
  min-height: 100vh;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 10% 8% 8%;
  overflow: hidden;
}

.detail-hero .bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.25) saturate(1.1);
  transform: scale(1.05);
  transition: transform 12s linear;
}

.detail-hero:hover .bg-img {
  transform: scale(1.16);
}

.detail-hero::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 70% 30%, rgba(212, 168, 83, 0.1) 0%, transparent 60%),
    linear-gradient(to top, var(--bg-deep) 0%, rgba(13, 11, 14, 0.3) 50%, rgba(13, 11, 14, 0.8) 100%);
  z-index: 1;
}

.detail-hero::before {
  content: '';
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  background: radial-gradient(ellipse at bottom left, rgba(232, 115, 90, 0.1) 0%, transparent 50%);
  z-index: 2;
  pointer-events: none;
}

.detail-content {
  position: relative;
  z-index: 10;
  max-width: 800px;
}

.detail-tagline {
  margin-bottom: 12px;
  font-family: var(--font-accent);
  color: var(--retro-red);
  letter-spacing: 0.4em;
  text-transform: uppercase;
  font-weight: 400;
  font-size: 0.85rem;
  opacity: 0.9;
}

.detail-title {
  font-family: var(--font-display);
  font-size: clamp(3rem, 7vw, 5.5rem);
  font-style: italic;
  font-weight: 500;
  letter-spacing: 0.12em;
  margin-bottom: 20px;
  text-shadow: 0 10px 40px rgba(0, 0, 0, 0.9);
  color: #eff5fb;
  text-transform: none;
}

.detail-meta {
  display: flex;
  gap: 35px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}

.detail-meta span {
  font-family: var(--font-accent);
  font-size: 1.2rem;
  color: var(--mocha);
  display: flex;
  align-items: center;
  gap: 8px;
}

.detail-meta span::after {
  content: '·';
  color: var(--sunset-coral);
  margin-left: 8px;
}

.detail-meta span:last-child::after {
  content: '';
}

.detail-synopsis {
  font-size: 1.25rem;
  line-height: 2;
  margin-top: 20px;
  max-width: 90%;
}

.detail-tagline {
  font-family: var(--font-display);
  color: var(--retro-mustard);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 10px;
  font-size: 1.1rem;
}

.editorial-section {
  padding: 80px 8%;
}

.editorial-flex {
  display: flex;
  gap: 80px;
}

.editorial-left {
  flex: 2;
}

.editorial-right {
  flex: 1;
}

.cast-list {
  list-style: none;
}

.cast-list li {
  padding: 20px 0;
  border-bottom: 1px solid rgba(212, 168, 83, 0.1);
  display: flex;
  justify-content: space-between;
  transition: var(--transition);
}

.cast-list li:hover {
  padding-left: 10px;
  border-bottom-color: var(--sunset-coral);
}

.cast-name {
  color: var(--gold);
  font-family: var(--font-display);
  font-size: 1.15rem;
}

.cast-role {
  color: var(--mocha);
  font-style: italic;
  font-family: var(--font-accent);
}

.ticket-tiers {
  display: flex;
  flex-direction: column;
  gap: 18px;
  margin-top: 20px;
}

.ticket-tier {
  background: var(--cream);
  color: var(--bg-deep);
  padding: 20px 35px;
  position: relative;
  border: none;
  cursor: pointer;
  border-radius: 4px;
  transition: var(--transition);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ticket-tier::before,
.ticket-tier::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 22px;
  height: 22px;
  background: var(--bg-deep);
  border-radius: 50%;
  transform: translateY(-50%);
}

.ticket-tier::before {
  left: -11px;
}

.ticket-tier::after {
  right: -11px;
}

.ticket-tier:hover {
  transform: scale(1.03) translateY(-2px);
  box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
}

.ticket-tier.selected {
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
}

.tier-name {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.tier-price {
  font-family: var(--font-accent);
  font-size: 1.4rem;
  font-style: italic;
}

.reviews-section {
  padding: 60px 0;
}

.reviews-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 30px;
  margin-top: 30px;
}

.review-card {
  background: var(--bg-card);
  border: 1px solid rgba(212, 168, 83, 0.1);
  padding: 30px;
  border-radius: 6px;
  transition: border-color 0.4s ease, transform 0.4s var(--ease-bounce), box-shadow 0.4s ease;
}

.review-card:hover {
  border-color: var(--sunset-coral);
  transform: translateY(-7px) rotate(0.3deg);
  box-shadow: 0 18px 40px rgba(232, 115, 90, 0.12);
}

.ink-stars {
  color: var(--sunset-coral);
  font-size: 1.3rem;
  letter-spacing: 4px;
  margin-bottom: 12px;
}

.review-text {
  font-size: 1.05rem;
  line-height: 1.7;
  margin-bottom: 15px;
  font-style: italic;
}

.review-author {
  font-family: var(--font-accent);
  color: var(--mocha);
  font-weight: 600;
}

.seat-booking-wrapper {
  padding: 120px 5% 60px;
  display: flex;
  gap: 40px;
  align-items: flex-start;
}

.theatre-blueprint {
  flex: 2;
  background: linear-gradient(145deg, #1a2a2a, #0f1f1f);
  border: 1.5px solid var(--gold);
  padding: 40px;
  border-radius: 10px;
  position: relative;
  overflow: hidden;
}

.theatre-blueprint::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: linear-gradient(rgba(212, 168, 83, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(212, 168, 83, 0.03) 1px, transparent 1px);
  background-size: 20px 20px;
  pointer-events: none;
}

.screen-curve {
  width: 70%;
  height: 50px;
  margin: 0 auto 50px;
  border-top: 3px solid var(--cream);
  border-radius: 50%/100% 100% 0 0;
  text-align: center;
  color: var(--cream);
  font-family: var(--font-accent);
  font-style: italic;
  letter-spacing: 0.3em;
  padding-top: 12px;
  box-shadow: 0 -15px 40px -10px rgba(242, 232, 213, 0.15);
  position: relative;
  z-index: 2;
}

.seat-map {
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: center;
  position: relative;
  z-index: 10;
}

.seat-row {
  display: flex;
  gap: 10px;
  justify-content: center;
  align-items: center;
}

.row-label {
  width: 25px;
  text-align: center;
  color: var(--gold);
  font-family: var(--font-accent);
  font-size: 1.1rem;
}

.seat {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  cursor: pointer;
  transition: all 0.3s var(--ease-bounce);
}

.seat.available {
  background: var(--cream);
  box-shadow: inset 0 -3px 0 rgba(0, 0, 0, 0.15);
}

.seat.available:hover {
  transform: scale(1.35) translateY(-2px);
  background: var(--gold-light);
  box-shadow: 0 4px 12px rgba(212, 168, 83, 0.4);
}

.seat.taken {
  background: var(--sunset-coral);
  cursor: not-allowed;
  opacity: 0.5;
}

.seat.selected {
  background: var(--gold);
  transform: scale(1.2);
  box-shadow: 0 0 18px var(--gold);
  animation: seat-pop 0.5s var(--ease-bounce);
}

.seat-legend {
  display: flex;
  justify-content: center;
  gap: 30px;
  margin-top: 40px;
  padding-top: 20px;
  border-top: 1px dashed rgba(212, 168, 83, 0.2);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-accent);
  font-size: 1rem;
}

.booking-panel {
  flex: 1;
  background: var(--bg-card);
  border: 1px solid rgba(212, 168, 83, 0.15);
  padding: 35px;
  border-radius: 8px;
}

.booking-summary-list {
  list-style: none;
  margin-bottom: 25px;
}

.booking-summary-list li {
  display: flex;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid rgba(212, 168, 83, 0.08);
  font-family: var(--font-accent);
  font-size: 1.15rem;
}

.booking-total {
  font-size: 1.6rem;
  color: var(--gold);
  font-weight: 600;
  font-family: var(--font-display);
}

.step-indicator {
  display: flex;
  justify-content: space-between;
  margin-bottom: 35px;
  position: relative;
}

.step-indicator::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 1px;
  background: rgba(212, 168, 83, 0.2);
  z-index: 0;
}

.step-dot {
  width: 42px;
  height: 42px;
  background: var(--bg-deep);
  border: 2px solid var(--mocha);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: var(--mocha);
  font-family: var(--font-accent);
  font-size: 1.1rem;
  position: relative;
  z-index: 1;
  transition: var(--transition);
}

.step-dot.active {
  border-color: var(--gold);
  color: var(--gold);
  background: var(--gold-dim);
  box-shadow: 0 0 20px rgba(212, 168, 83, 0.3);
}

.ticket-reveal-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(13, 11, 14, 0.92);
  z-index: 99999;
  justify-content: center;
  align-items: center;
  backdrop-filter: blur(10px);
}

.ticket-reveal-modal.active {
  display: flex;
}

.e-ticket {
  background: var(--cream);
  width: 750px;
  max-width: 90vw;
  display: flex;
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 30px 80px rgba(0, 0, 0, 0.8);
  transform: translateY(80px) scale(0.88);
  opacity: 0;
  transition: all 0.75s var(--ease-bounce);
}

.ticket-reveal-modal.show .e-ticket {
  transform: translateY(0) scale(1);
  opacity: 1;
}

.e-ticket-main {
  flex: 3;
  padding: 35px;
  border-right: 2px dashed var(--mocha);
  position: relative;
  color: var(--bg-deep);
}

.e-ticket-stub {
  flex: 1;
  padding: 25px;
  background: rgba(212, 168, 83, 0.1);
  color: var(--bg-deep);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.watermark {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-25deg);
  font-size: 6rem;
  opacity: 0.04;
  pointer-events: none;
  font-family: var(--font-display);
  font-weight: 700;
}

.timeline-section {
  padding: 150px 8% 80px;
  min-height: 100vh;
  background: var(--bg-dark);
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 40px;
  align-items: center;
  position: relative;
}

.timeline::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 2px;
  background: linear-gradient(to bottom, var(--gold), var(--sunset-coral), var(--sunset-lavender));
}

.timeline-item {
  width: 42%;
  position: relative;
}

.timeline-item:nth-child(odd) {
  align-self: flex-start;
}

.timeline-item:nth-child(even) {
  align-self: flex-end;
}

.timeline-item::after {
  content: '';
  position: absolute;
  top: 20px;
  width: 14px;
  height: 14px;
  background: var(--sunset-coral);
  border-radius: 50%;
  box-shadow: 0 0 12px rgba(232, 115, 90, 0.6);
  z-index: 10;
}

.timeline-item:nth-child(odd)::after {
  right: -37px;
}

.timeline-item:nth-child(even)::after {
  left: -37px;
}

.stub-card {
  perspective: 1500px;
  height: 220px;
  position: relative;
  transition: transform 0.6s var(--ease-smooth);
}

.timeline-item:nth-child(odd) .stub-card {
  transform: rotate(-1.5deg);
}

.timeline-item:nth-child(even) .stub-card {
  transform: rotate(1.5deg);
}

.stub-card-inner {
  width: 100%;
  height: 100%;
  transition: transform 0.85s var(--ease-smooth);
  transform-style: preserve-3d;
  position: relative;
}

.stub-card:hover .stub-card-inner {
  transform: rotateY(180deg);
}

.stub-front,
.stub-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 30px;
  border-radius: 4px;
  box-shadow: 0 15px 45px rgba(0, 0, 0, 0.5);
  background: #fdfaf5;
  overflow: hidden;
  color: #1a1520;
  border: 4px double rgba(13, 11, 14, 0.2);
}

.stub-front::before,
.stub-front::after {
  content: '';
  position: absolute;
  width: 34px;
  height: 34px;
  background: var(--bg-deep);
  border-radius: 50%;
  z-index: 5;
}

.stub-front::before {
  left: -17px;
  top: calc(50% - 17px);
}

.stub-front::after {
  right: -17px;
  top: calc(50% - 17px);
}

.stub-serial {
  position: absolute;
  top: 20px;
  left: 25px;
  font-family: 'Courier New', monospace;
  font-weight: 700;
  font-size: 0.8rem;
  letter-spacing: 0.2em;
  color: var(--retro-red);
  transform: rotate(-90deg) translateX(-100%);
  transform-origin: left top;
  opacity: 0.8;
}

.stub-title {
  font-family: var(--font-display);
  font-size: 2.2rem;
  font-style: italic;
  line-height: 1.1;
  text-align: center;
  margin: 10px 0;
  color: #1a1520;
}

.stub-meta {
  margin-top: 10px;
  font-family: var(--font-accent);
  text-transform: uppercase;
  font-size: 0.85rem;
  letter-spacing: 0.15em;
  font-weight: 700;
  opacity: 0.7;
}

.stub-back {
  background: #1a1520;
  color: #fdfaf5;
  transform: rotateY(180deg);
  border: 4px double rgba(212, 168, 83, 0.3);
}

.stub-qr-mock {
  width: 80px;
  height: 80px;
  background: repeating-linear-gradient(45deg, #fdfaf5 0 2px, transparent 0 4px), repeating-linear-gradient(-45deg, #fdfaf5 0 2px, transparent 0 4px);
  opacity: 0.2;
  border: 1px solid rgba(253, 250, 245, 0.1);
  margin-bottom: 15px;
}

.manifesto {
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(1.8rem, 4vw, 3.2rem);
  line-height: 1.5;
  text-align: center;
  max-width: 900px;
  margin: 0 auto 100px;
  color: var(--gold);
}

.mag-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  margin-bottom: 100px;
  padding: 0 5%;
}

.mag-img-wrap img {
  width: 100%;
  border-radius: 8px;
  filter: grayscale(40%) sepia(15%) contrast(1.1);
  transition: var(--transition);
}

.mag-img-wrap:hover img {
  filter: grayscale(0%) sepia(0%);
}

.stats-container {
  display: flex;
  justify-content: space-around;
  padding: 80px 5%;
  border-top: 1px solid rgba(212, 168, 83, 0.15);
  border-bottom: 1px solid rgba(212, 168, 83, 0.15);
}

.stat-box {
  text-align: center;
}

.stat-number {
  font-family: var(--font-display);
  font-size: clamp(3rem, 5vw, 4.5rem);
  color: var(--gold);
}

.stat-label {
  font-family: var(--font-accent);
  font-size: 1.1rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--mocha);
  margin-top: 5px;
}

.account-wrapper {
  padding: 150px 8% 80px;
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 60px;
}

.membership-card {
  background: linear-gradient(135deg, var(--gold), #b8933e, var(--gold-light));
  height: 230px;
  border-radius: 16px;
  padding: 30px;
  color: var(--bg-deep);
  position: relative;
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  overflow: hidden;
}

.membership-card::before {
  content: '';
  position: absolute;
  top: -60px;
  right: -40px;
  width: 180px;
  height: 180px;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.member-name {
  font-family: var(--font-display);
  font-size: 1.7rem;
  text-transform: uppercase;
  margin-top: 50px;
  letter-spacing: 0.12em;
}

.member-num {
  font-family: 'Courier New', monospace;
  font-size: 1.1rem;
  margin-top: 12px;
  letter-spacing: 0.15em;
  opacity: 0.7;
}

.voucher-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
}

.coupon-card {
  background: var(--bg-card);
  border: 2px dashed rgba(212, 168, 83, 0.4);
  padding: 30px;
  text-align: center;
  position: relative;
  border-radius: 6px;
  transition: var(--transition);
}

.coupon-card:hover {
  border-color: var(--sunset-coral);
  transform: translateY(-5px);
}

.coupon-card::before,
.coupon-card::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 25px;
  height: 25px;
  background: var(--bg-deep);
  border-radius: 50%;
  transform: translateY(-50%);
}

.coupon-card::before {
  left: -13px;
}

.coupon-card::after {
  right: -13px;
}

.acc-item {
  border-bottom: 1px solid rgba(212, 168, 83, 0.1);
}

.acc-header {
  padding: 20px 0;
  cursor: pointer;
  font-family: var(--font-display);
  font-size: 1.3rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: var(--gold);
  transition: var(--transition);
}

.acc-header:hover {
  color: var(--sunset-coral);
}

.acc-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s var(--ease-smooth);
}

.acc-item.active .acc-content {
  max-height: 500px;
}

.acc-icon {
  transition: transform 0.35s var(--ease-bounce);
  font-size: 1rem;
}

.acc-item.active .acc-icon {
  transform: rotate(180deg);
}

.org-wrapper {
  background: linear-gradient(180deg, var(--bg-dark), var(--bg-deep));
  min-height: 100vh;
}

.data-card-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25px;
  margin-bottom: 40px;
}

.data-card {
  background: var(--bg-card);
  border: 1px solid rgba(212, 168, 83, 0.12);
  padding: 28px;
  border-radius: 8px;
  transition: var(--transition);
}

.data-card:hover {
  border-color: var(--sunset-coral);
  transform: translateY(-6px);
  box-shadow: 0 12px 32px rgba(232, 115, 90, 0.12);
}

.data-card h3 {
  font-family: var(--font-accent);
  font-size: 1rem;
  color: var(--mocha);
  margin-bottom: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.data-card .value {
  font-family: var(--font-display);
  font-size: 2.5rem;
  color: var(--gold);
}

.charts-row {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 30px;
  margin-bottom: 40px;
}

.chart-container {
  background: var(--bg-card);
  border: 1px solid rgba(212, 168, 83, 0.1);
  padding: 25px;
  border-radius: 8px;
}

.dropzone {
  border: 3px dashed rgba(212, 168, 83, 0.3);
  background: rgba(212, 168, 83, 0.03);
  height: 250px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  transition: var(--transition);
  border-radius: 8px;
}

.dropzone.dragover {
  border-color: var(--sunset-coral);
  background: rgba(232, 115, 90, 0.05);
}

.dropzone-icon {
  font-size: 4rem;
  color: var(--mocha);
  margin-bottom: 15px;
}

footer {
  text-align: center;
  padding: 80px 20px;
  border-top: 1px solid rgba(212, 168, 83, 0.1);
  background: var(--bg-deep);
  position: relative;
  z-index: 10;
}

footer .logo-img {
  height: 50px;
  margin-bottom: 20px;
  filter: drop-shadow(0 0 10px rgba(212, 168, 83, 0.2));
}

footer .footer-links {
  display: flex;
  justify-content: center;
  gap: 30px;
  margin-top: 20px;
  flex-wrap: wrap;
}

footer .footer-links a {
  font-family: var(--font-accent);
  font-size: 1rem;
  color: var(--mocha);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  transition: var(--transition);
}

footer .footer-links a:hover {
  color: var(--gold);
}

footer p {
  color: var(--mocha);
  font-family: var(--font-accent);
  font-style: italic;
  font-size: 1.1rem;
}

.home-hero {
  min-height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  text-align: center;
}

.home-hero .hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  filter: brightness(0.25) saturate(1.4);
  z-index: 0;
}

.home-hero::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at center, rgba(13, 11, 14, 0.2) 0%, rgba(13, 11, 14, 0.85) 100%);
  z-index: 1;
}

.home-hero .hero-content {
  position: relative;
  z-index: 10;
  max-width: 800px;
  padding: 0 20px;
}

.home-hero .hero-logo {
  height: 120px;
  margin-bottom: 30px;
  filter: drop-shadow(0 0 40px rgba(212, 168, 83, 0.4));
}

.home-hero .hero-tagline {
  font-family: var(--font-accent);
  font-size: 1.4rem;
  color: var(--mocha);
  font-style: italic;
  letter-spacing: 0.15em;
  margin-bottom: 40px;
}

.home-hero .hero-cta {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
}

.home-hero .scroll-hint {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: var(--mocha);
  font-family: var(--font-accent);
  font-size: 0.9rem;
  letter-spacing: 0.1em;
  animation: float-hint 2.5s ease-in-out infinite;
}

.scroll-hint svg {
  opacity: 0.5;
}

.section-header {
  text-align: center;
  margin-bottom: 60px;
}

.section-header h2 {
  margin-bottom: 12px;
}

.section-header p {
  font-family: var(--font-accent);
  color: var(--mocha);
  font-style: italic;
  font-size: 1.2rem;
  max-width: 600px;
  margin: 0 auto;
}

.featured-section {
  padding: 100px 5%;
}

.experience-section {
  padding: 120px 5%;
  position: relative;
  overflow: hidden;
}

.experience-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 30px;
}

.exp-card {
  background: var(--bg-card);
  border: 1px solid rgba(212, 168, 83, 0.08);
  border-radius: 10px;
  padding: 40px 30px;
  text-align: center;
  transition: var(--transition);
  position: relative;
  overflow: hidden;
}

.exp-card:hover {
  transform: translateY(-10px) scale(1.01);
  border-color: var(--sunset-coral);
  box-shadow: 0 22px 45px rgba(232, 115, 90, 0.12);
}

.exp-card .exp-icon {
  font-size: 3rem;
  margin-bottom: 20px;
  display: block;
}

.exp-card h3 {
  margin-bottom: 12px;
  font-size: 1.4rem;
}

.exp-card p {
  font-size: 1rem;
  line-height: 1.7;
}

.exp-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--gold), var(--sunset-coral));
  transform: scaleX(0);
  transition: transform 0.5s var(--ease-smooth);
  transform-origin: left;
}

.exp-card:hover::before {
  transform: scaleX(1);
}

.about-preview {
  padding: 120px 5%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

.about-preview .img-wrap {
  position: relative;
  border-radius: 10px;
  overflow: hidden;
}

.about-preview .img-wrap img {
  width: 100%;
  display: block;
  filter: grayscale(30%) sepia(10%) contrast(1.05);
  transition: filter 0.5s;
  border-radius: 10px;
}

.about-preview .img-wrap:hover img {
  filter: grayscale(0%) sepia(0%);
}

.about-preview .img-wrap::after {
  content: '';
  position: absolute;
  top: 15px;
  left: 15px;
  right: -15px;
  bottom: -15px;
  border: 1.5px solid var(--gold);
  border-radius: 10px;
  z-index: -1;
  opacity: 0.3;
}

.about-text h2 {
  margin-bottom: 25px;
}

.about-text p {
  margin-bottom: 20px;
  font-size: 1.1rem;
  line-height: 1.9;
}

.cta-section {
  padding: 120px 5%;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.cta-section::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 800px;
  height: 800px;
  background: radial-gradient(circle, rgba(232, 115, 90, 0.08) 0%, transparent 70%);
  transform: translate(-50%, -50%);
  border-radius: 50%;
}

.cta-section h2 {
  font-size: clamp(2rem, 4vw, 3.5rem);
  margin-bottom: 15px;
  color: var(--cream);
}

.cta-section p {
  font-family: var(--font-accent);
  color: var(--mocha);
  font-size: 1.2rem;
  font-style: italic;
  margin-bottom: 40px;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.swiper {
  width: 100%;
  border-radius: 10px;
  overflow: hidden;
}

.swiper-slide {
  transition: transform 0.5s, opacity 0.5s;
}

.swiper-pagination-bullet {
  background: var(--gold) !important;
  opacity: 0.4;
}

.swiper-pagination-bullet-active {
  opacity: 1 !important;
}

.css-poster {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
  position: relative;
  overflow: hidden;
}

.css-poster::before {
  content: '';
  position: absolute;
  top: 10px;
  left: 10px;
  right: 10px;
  bottom: 10px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  pointer-events: none;
}

.css-poster-budapest {
  background: linear-gradient(135deg, #d38b97 0%, #a45a66 100%);
}

.css-poster-budapest .c-title {
  font-family: 'Oswald', sans-serif;
  font-size: 2rem;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 10px;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
}

.css-poster-budapest .c-tag {
  font-family: 'Oswald', sans-serif;
  font-size: 1rem;
  color: #f4d7d7;
  font-style: italic;
}

.css-poster-blade {
  background: linear-gradient(to bottom, #113444 0%, #dc6c37 100%);
}

.css-poster-blade .c-title {
  font-family: 'Courier New', monospace;
  font-size: 2.2rem;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  font-weight: bold;
  margin-bottom: 10px;
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.4);
}

.css-poster-blade .c-tag {
  font-family: 'Courier New', monospace;
  font-size: 0.9rem;
  color: #feca9e;
  letter-spacing: 0.2em;
}

.css-poster-godfather {
  background: radial-gradient(circle at center, #301010 0%, #080808 100%);
}

.css-poster-godfather .c-title {
  font-family: 'Oswald', sans-serif;
  font-size: 2.5rem;
  color: #c4b69d;
  font-weight: bold;
  margin-bottom: 10px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  line-height: 1;
}

.css-poster-godfather .c-tag {
  font-family: var(--font-body);
  font-size: 1.1rem;
  color: #856847;
  font-style: italic;
  border-top: 1px solid #856847;
  padding-top: 10px;
  margin-top: 5px;
}

.css-poster-odyssey {
  background: linear-gradient(180deg, #000 0%, #050510 50%, #200000 100%);
}

.css-poster-odyssey .c-title {
  font-family: 'Helvetica Neue', sans-serif;
  font-size: 1.8rem;
  color: #eff5fb;
  letter-spacing: 0.3em;
  font-weight: 300;
  margin-bottom: 15px;
  text-transform: uppercase;
}

.css-poster-odyssey .c-tag {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #fff, #f00 40%, #500);
  margin: 0 auto;
  box-shadow: 0 0 30px rgba(255, 0, 0, 0.5);
}

.typewriter-input {
  background: transparent;
  border: none;
  border-bottom: 1px dotted var(--mocha);
  font-family: 'Courier New', Courier, monospace;
  color: var(--gold);
  font-size: 1.2rem;
  width: 100%;
  padding: 5px;
  outline: none;
  transition: var(--transition);
}

.typewriter-input:focus {
  border-bottom-color: var(--sunset-coral);
}

.fade-up {
  opacity: 0;
  transform: translateY(55px);
  filter: blur(5px);
  transition:
    opacity 0.9s var(--ease-smooth),
    transform 0.9s var(--ease-smooth),
    filter 0.7s var(--ease-smooth);
}

.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
  filter: blur(0);
}

.fade-left {
  opacity: 0;
  transform: translateX(-55px) scale(0.97);
  filter: blur(4px);
  transition:
    opacity 0.9s var(--ease-smooth),
    transform 0.9s var(--ease-smooth),
    filter 0.7s var(--ease-smooth);
}

.fade-left.visible {
  opacity: 1;
  transform: translateX(0) scale(1);
  filter: blur(0);
}

.fade-right {
  opacity: 0;
  transform: translateX(55px) scale(0.97);
  filter: blur(4px);
  transition:
    opacity 0.9s var(--ease-smooth),
    transform 0.9s var(--ease-smooth),
    filter 0.7s var(--ease-smooth);
}

.fade-right.visible {
  opacity: 1;
  transform: translateX(0) scale(1);
  filter: blur(0);
}

.scale-in {
  opacity: 0;
  transform: scale(0.85);
  filter: blur(6px);
  transition:
    opacity 0.85s var(--ease-smooth),
    transform 0.85s var(--ease-bounce),
    filter 0.85s var(--ease-smooth);
}

.scale-in.visible {
  opacity: 1;
  transform: scale(1);
  filter: blur(0);
}

.skew-up {
  opacity: 0;
  transform: translateY(90px) skewY(5deg);
  transform-origin: top left;
  transition:
    opacity 1.1s var(--ease-smooth),
    transform 1.1s var(--ease-smooth);
}

.skew-up.visible {
  opacity: 1;
  transform: translateY(0) skewY(0deg);
}

.blur-in {
  opacity: 0;
  filter: blur(18px) brightness(1.3);
  transform: scale(1.04);
  transition:
    opacity 1.4s var(--ease-smooth),
    filter 1.4s var(--ease-smooth),
    transform 1.4s var(--ease-smooth);
}

.blur-in.visible {
  opacity: 1;
  filter: blur(0) brightness(1);
  transform: scale(1);
}

.text-reveal {
  opacity: 0;
  clip-path: polygon(0 100%, 100% 100%, 100% 100%, 0 100%);
  transform: translateY(14px);
  transition:
    clip-path 1.1s var(--ease-bounce),
    transform 1.1s var(--ease-bounce),
    opacity 0.4s ease;
}

.text-reveal.visible {
  opacity: 1;
  clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
  transform: translateY(0);
}

.drift-in {
  opacity: 0;
  transform: translateX(-28px) translateY(22px) rotate(-1.2deg);
  transition:
    opacity 1.2s var(--ease-smooth),
    transform 1.2s var(--ease-smooth);
}

.drift-in.visible {
  opacity: 1;
  transform: translateX(0) translateY(0) rotate(0deg);
}

.rise {
  opacity: 0;
  transform: translateY(65px) scale(0.96);
  filter: brightness(0.5);
  transition:
    opacity 1s var(--ease-smooth),
    transform 1s var(--ease-bounce),
    filter 1s ease;
}

.rise.visible {
  opacity: 1;
  transform: translateY(0) scale(1);
  filter: brightness(1);
}

.flip-in {
  opacity: 0;
  transform: perspective(800px) rotateX(25deg) translateY(40px);
  transform-origin: top center;
  transition:
    opacity 1s var(--ease-smooth),
    transform 1s var(--ease-smooth);
}

.flip-in.visible {
  opacity: 1;
  transform: perspective(800px) rotateX(0deg) translateY(0);
}

.stagger-children>*:nth-child(1) {
  transition-delay: 0s;
}

.stagger-children>*:nth-child(2) {
  transition-delay: 0.1s;
}

.stagger-children>*:nth-child(3) {
  transition-delay: 0.2s;
}

.stagger-children>*:nth-child(4) {
  transition-delay: 0.3s;
}

.stagger-children>*:nth-child(5) {
  transition-delay: 0.4s;
}

.stagger-children>*:nth-child(6) {
  transition-delay: 0.5s;
}

.stagger-children>*:nth-child(7) {
  transition-delay: 0.6s;
}

.stagger-children>*:nth-child(8) {
  transition-delay: 0.7s;
}

@media (max-width: 1024px) {
  .editorial-flex {
    flex-direction: column;
  }

  .seat-booking-wrapper {
    flex-direction: column;
  }

  .account-wrapper {
    grid-template-columns: 1fr;
  }

  .data-card-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .charts-row {
    grid-template-columns: 1fr;
  }

  .mag-layout {
    grid-template-columns: 1fr;
  }

  .experience-grid {
    grid-template-columns: 1fr 1fr;
  }

  .about-preview {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .timeline-item {
    width: 80%;
  }

  .timeline::before {
    left: 20px;
  }

  .timeline-item:nth-child(odd)::after,
  .timeline-item:nth-child(even)::after {
    left: -25px;
  }
}

@media (max-width: 768px) {
  .nav-links {
    display: none;
  }

  .movies-grid {
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .voucher-grid {
    grid-template-columns: 1fr;
  }

  .experience-grid {
    grid-template-columns: 1fr;
  }

  .home-hero .hero-cta {
    flex-direction: column;
    align-items: center;
  }
}

/* LIQUID GLASS STYLES */
.liquidGlass-wrapper {
  position: relative;
  display: flex;
  font-weight: 600;
  overflow: hidden;
  box-shadow: 0 6px 6px rgba(0, 0, 0, 0.2), 0 0 20px rgba(0, 0, 0, 0.1);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 2.2);
}

.liquidGlass-effect {
  position: absolute;
  z-index: 0;
  inset: 0;
  backdrop-filter: blur(8px);
  filter: url(#glass-distortion);
  overflow: hidden;
}

.liquidGlass-tint {
  z-index: 1;
  position: absolute;
  inset: 0;
  background: rgba(30, 25, 40, 0.40);
  /* Adjusted for dark theme */
}

.liquidGlass-shine {
  position: absolute;
  inset: 0;
  z-index: 2;
  overflow: hidden;
  box-shadow: inset 2px 2px 1px 0 rgba(255, 255, 255, 0.1),
    inset -1px -1px 1px 1px rgba(255, 255, 255, 0.05);
}

.liquidGlass-content {
  z-index: 3;
  width: 100%;
  position: relative;
}